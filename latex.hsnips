context math(context)
snippet `ddx` "First derivative" A
\frac{d $1}{dx}$0
endsnippet

context math(context)
snippet `d(\w+)d(\w+)` "Derivative" A
\frac{d^{``rv=m[1]``} $1}{d``rv=m[2]``^{``rv=m[1]``}}$0
endsnippet

context math(context)
snippet `int(\w+)d(\w+)` "Derivative" A
\int_{``rv=m[1]``}^{$1}$2d``rv=m[2]``
endsnippet

context math(context)
snippet `lim(\w+)` "Derivative" A
\lim_{``rv=m[1]`` \to $1} $0
endsnippet

context math(context)
snippet `pr(\w+)pr(\w+)` "Derivative" A
\frac{\partial^{``rv=m[1]``} $1}{\partial ``rv=m[2]``^{``rv=m[1]``}}$0
endsnippet

context math(context)
snippet `prpr(\w+)` "Derivative" A
\frac{\partial $1}{\partial x^{``rv=m[1]``}}$0
endsnippet
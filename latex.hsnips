global
function math(context) {
    return context.scopes.some(
		s => s.startsWith("meta.math")
	)
	&& !context.scopes.some(
		s => (
			s.startsWith("comment")
			|| s.startsWith("meta.definition.label")
			|| s.startsWith("meta.reference.label")
			|| s.startsWith("meta.text.normal.tex")
		)
	);
}
endglobal

snippet mk "Inline math mode" A
$$1$$0
endsnippet

snippet dk "Display math mode" A
\[
    $1
\]$0
endsnippet

snippet qj "Align environment" A
\begin{align}
    $1
\end{align}$0
endsnippet

context math(context)
snippet `=> ` "\Rightarrow" A
\Rightarrow$0
endsnippet

context math(context)
snippet `<=>` "\Rightarrow" A
\iff$0
endsnippet

context math(context)
snippet `-> ` "\to" A
\to$0
endsnippet

context math(context)
snippet `\* ` "\times" A
\times$0
endsnippet

context math(context)
snippet // "Fraction simple" A
\frac{$1}{$2}$0
endsnippet

context math(context)
snippet `\~` "Fraction simple" A
\approx 
endsnippet

context math(context)
snippet `oo` "Superscript after number" A
\infty 
endsnippet

context math(context)
snippet `((\d+)|(\d*)(\\)?([A-Za-z]+)((\^|_)(\{\d+\}|\d))*)/` "Fraction no ()" A
\frac{``rv = m[1]``}{$1}$0
endsnippet

context math(context)
snippet `^.*\)/` "Fraction with ()" A
``
    let str = m[0];
    str = str.slice(0, -1);
    let lastIndex = str.length - 1;

    let depth = 0;
    let i = str.length - 1;

    while (true) {
        if (str[i] == ')') depth += 1;
        if (str[i] == '(') depth -= 1;
        if (depth == 0) break;
        i -= 1;
    }

    let results = str.slice(0, i) + "\\frac{" + str.slice(i+1, -1) + "}";
    results += '{' + snip.tabstop(1, "") + "} " + snip.tabstop(0, "");
    rv = results;
    ``
endsnippet

context math(context)
snippet `((\d+)|(\d*)(\\)?([A-Za-z]+)((\^|_)(\{\d+\}|\d))*)\^` "Superscript after number" A
``rv=m[1]``^{$1}$0
endsnippet

context math(context)
snippet `((\d+)|(\d*)(\\)?([A-Za-z]+)((\^|_)(\{\d+\}|\d))*)_` "Superscript after number" A
``rv=m[1]``_{   $1}$0
endsnippet

context math(context)
snippet `((\d+)|(\d*)(\\)?([A-Za-z]+)((\^|_)(\{\d+\}|\d))*)->` "Superscript after number" A
\overrightarrow{``rv=m[1]``} $0
endsnippet

